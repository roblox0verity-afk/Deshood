    d.Info.Size = 12
    d.Info.Outline = true
    d.Info.Center = true
    d.Info.Color = Color3.new(1,1,1)
end

-- UPDATE ESP + SOUND ALERTS
local function UpdateESP()
    if not Settings.ESPEnabled then
        for _,d in pairs(ESPStorage) do
            d.Tracer.Visible = false; d.HealthBar.Visible = false; d.Info.Visible = false
        end
        return
    end
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local enemyTargetingTeam = false

    -- TEAM ESP + HP DROP ALERT
    for _,plr in ipairs(Settings.Team) do
        if not plr or not plr:IsDescendantOf(Players) then continue end
        if not plr.Character then
            if ESPStorage[plr] then
                ESPStorage[plr].Tracer.Visible = false
                ESPStorage[plr].HealthBar.Visible = false
                ESPStorage[plr].Info.Visible = false
            end
            continue
        end
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp or hum.Health <= 0 then
            if ESPStorage[plr] then
                ESPStorage[plr].Tracer.Visible = false
                ESPStorage[plr].HealthBar.Visible = false
                ESPStorage[plr].Info.Visible = false
            end
            continue
        end

        -- HP Drop Check + Sound
        if Settings.TeamWarningEnabled then
            local currentHP = math.floor(hum.Health)
            if LastTeamHP[plr] and (LastTeamHP[plr] - currentHP) >= Settings.TeamHPDropThreshold then
                Notify(plr.DisplayName.." under attack | "..currentHP.." HP", 4)
                PlayRandomAlert()
            end
            LastTeamHP[plr] = currentHP
        end

        SetupESP(plr)
        local d = ESPStorage[plr]
        local pos, onScr = Camera:WorldToViewportPoint(hrp.Position)
        local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
        if onScr and pos.Z > 0 and pos.Z < Settings.MaxDistance then
            d.Tracer.Visible = Settings.TracerEnabled
            d.Tracer.Color = Color3.new(0.2, 0.8, 0.2)
            d.HealthBar.Visible = true
            d.HealthBar.Color = Color3.new(0.2, 0.8, 0.2)
            d.Info.Visible = true
            d.Tracer.From = center; d.Tracer.To = Vector2.new(pos.X, pos.Y)
            d.HealthBar.Position = Vector2.new(pos.X - 22, pos.Y - 25)
            d.HealthBar.Size = Vector2.new(3, 25 * math.clamp(hum.Health/hum.MaxHealth, 0,1))
            d.Info.Position = Vector2.new(pos.X, pos.Y - 45)
            d.Info.Text = string.format("%s | %d m | %d HP", plr.DisplayName, dist, math.floor(hum.Health))
        else
            d.Tracer.Visible = false; d.HealthBar.Visible = false; d.Info.Visible = false
        end
    end

    -- ENEMY ESP + TARGET CHECK
    for _,plr in ipairs(Settings.Enemies) do
        if not plr or not plr:IsDescendantOf(Players) then continue end
        if not plr.Character then
            if ESPStorage[plr] then
                ESPStorage[plr].Tracer.Visible = false
                ESPStorage[plr].HealthBar.Visible = false
                ESPStorage[plr].Info.Visible = false
            end
            continue
        end
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp or hum.Health <= 0 then
            if ESPStorage[plr] then
                ESPStorage[plr].Tracer.Visible = false
                ESPStorage[plr].HealthBar.Visible = false
                ESPStorage[plr].Info.Visible = false
            end
            continue
        end

        -- Check if enemy is targeting team
        if Settings.TeamWarningEnabled and CurrentTargetChar then
            local targetPlr = Players:GetPlayerFromCharacter(CurrentTargetChar)
            if targetPlr and table.find(Settings.Team, targetPlr) then
                enemyTargetingTeam = true
            end
        end

        SetupESP(plr)
        local d = ESPStorage[plr]
        local pos, onScr = Camera:WorldToViewportPoint(hrp.Position)
        local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)
        if onScr and pos.Z > 0 and pos.Z < Settings.MaxDistance then
            d.Tracer.Visible = Settings.TracerEnabled
            d.Tracer.Color = Color3.new(0.8, 0.2, 0.2)
            d.HealthBar.Visible = true
            d.HealthBar.Color = Color3.new(0.8, 0.2, 0.2)
            d.Info.Visible = true
            d.Tracer.From = center; d.Tracer.To = Vector2.new(pos.X, pos.Y)
            d.HealthBar.Position = Vector2.new(pos.X - 22, pos.Y - 25)
            d.HealthBar.Size = Vector2.new(3, 25 * math.clamp(hum.Health/hum.MaxHealth, 0,1))
            d.Info.Position = Vector2.new(pos.X, pos.Y - 45)
            d.Info.Text = string.format("%s | %d m | %d HP", plr.DisplayName, dist, math.floor(hum.Health))
        else
            d.Tracer.Visible = false; d.HealthBar.Visible = false; d.Info.Visible = false
        end
    end

    -- Alert if enemy targets team
    if enemyTargetingTeam and Settings.TeamWarningEnabled then
        Notify("Enemy targeting your team!", 2)
        PlayRandomAlert()
    end
end
