-- VISIBILITY CHECKS
local function IsOnScreen(part)
    if not part or not part:IsDescendantOf(Workspace) then return false end
    local pos, visible = Camera:WorldToViewportPoint(part.Position)
    return visible and pos.Z > 1 and pos.Z < Settings.MaxDistance
end

local function IsVisible(part)
    if not Settings.WallCheck or not part then return true end
    local ray = RaycastParams.new()
    ray.FilterDescendantsInstances = {Character, Camera}
    ray.FilterType = Enum.RaycastFilterType.Exclude
    ray.IgnoreWater = true
    local result = Workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, ray)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- BODY PART SELECTOR
local function GetRandomBodyPart(char)
    local parts = {
        char:FindFirstChild("Head"),
        char:FindFirstChild("UpperTorso"),
        char:FindFirstChild("LowerTorso"),
        char:FindFirstChild("RightUpperArm"),
        char:FindFirstChild("LeftUpperArm"),
        char:FindFirstChild("RightUpperLeg"),
        char:FindFirstChild("LeftUpperLeg")
    }
    local valid = {}
    for _,p in ipairs(parts) do if p and p:IsDescendantOf(Workspace) then table.insert(valid, p) end end
    return valid[math.random(#valid)]
end

-- PART SWITCH LOGIC
local function ShouldSwitchPart(hrp)
    if not hrp then return false end
    local currentVel = hrp.Velocity
    local speed = currentVel.Magnitude

    if speed < Settings.VelocityThreshold then
        LastVelocity = currentVel
        LastDirection = currentVel.Unit
        return false
    end

    local directionDelta = math.acos(math.clamp(LastDirection:Dot(currentVel.Unit), -1, 1))
    local enoughTimePassed = (os.clock() - LastPartSwitch) > Settings.PartSwitchInterval

    if enoughTimePassed and (math.abs(speed - LastVelocity.Magnitude) > 0.5 or directionDelta > Settings.DirectionChangeThreshold) then
        LastVelocity = currentVel
        LastDirection = currentVel.Unit
        return true
    end

    return false
end

-- TARGET LOGIC
local function GetBestTarget()
    if not Humanoid or Humanoid.Health < Settings.UnlockWhenMyHPBelow then
        CurrentTargetChar = nil; CurrentAimPart = nil; return nil
    end
    if not Settings.AimlockEnabled or #Settings.Enemies == 0 then
        CurrentTargetChar = nil; CurrentAimPart = nil; return nil
    end

    if CurrentTargetChar and CurrentTargetChar:IsDescendantOf(Workspace) then
        local hum = CurrentTargetChar:FindFirstChildOfClass("Humanoid")
        local hrp = CurrentTargetChar:FindFirstChild("HumanoidRootPart")
        if hum and hrp and hum.Health >= Settings.MinEnemyHPToLock and hum.Health > 0
        and IsOnScreen(CurrentTargetChar.Head) and IsVisible(CurrentTargetChar.Head) then
            if ShouldSwitchPart(hrp) then
                CurrentAimPart = GetRandomBodyPart(CurrentTargetChar)
                LastPartSwitch = os.clock()
            end
            return CurrentTargetChar
        end
        CurrentTargetChar = nil; CurrentAimPart = nil
    end

    local bestChar = nil; local bestDist = math.huge
    for _,enemy in ipairs(Settings.Enemies) do
        if not enemy or not enemy.Character then continue end
        local hum = enemy.Character:FindFirstChildOfClass("Humanoid")
        local head = enemy.Character:FindFirstChild("Head")
        if not hum or not head or hum.Health < Settings.MinEnemyHPToLock or hum.Health <= 0 then continue end
        if not IsOnScreen(head) or not IsVisible(head) then continue end

        local dist = (Camera.CFrame.Position - head.Position).Magnitude
        if dist < bestDist then bestDist = dist; bestChar = enemy.Character end
    end

    if bestChar then
        CurrentTargetChar = bestChar
        CurrentAimPart = GetRandomBodyPart(bestChar)
        LastPartSwitch = os.clock()
        LastVelocity = bestChar:FindFirstChild("HumanoidRootPart").Velocity
        LastDirection = LastVelocity.Unit
    else
        CurrentTargetChar = nil; CurrentAimPart = nil
    end

    return CurrentTargetChar
end

-- AIM POSITION
local function GetAimPos(part)
    if not part then return nil end
    local hrp = part.Parent:FindFirstChild("HumanoidRootPart")
    local predicted = part.Position
    if hrp then predicted += hrp.Velocity * Settings.Prediction end
    return predicted + Vector3.new(0, Settings.AimOffset, 0)
end

