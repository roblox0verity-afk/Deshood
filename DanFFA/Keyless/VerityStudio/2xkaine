RunService.RenderStepped:Connect(function(deltaTime)
    -- Aimlock
    local target = GetBestTarget()
    if target and CurrentAimPart then
        local aimPos = GetAimPos(CurrentAimPart)
        if aimPos then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, aimPos), Settings.AimSpeed)
        end
    end

    -- Update ESP
    UpdateESP()
end)

