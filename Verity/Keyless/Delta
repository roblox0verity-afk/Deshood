-- SMART SEARCH
local function SmartFindPlayer(input)
    input = input:lower():gsub("%s", "")
    if input == "" then return nil end
    local bestMatch = nil
    local bestScore = math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local userName = plr.Name:lower()
        local displayName = plr.DisplayName:lower()
        if userName == input or displayName == input then return plr end
        local score = 0
        if userName:find(input, 1, true) then score -= 20 end
        if displayName:find(input, 1, true) then score -= 20 end
        score += math.abs(#userName - #input) + math.abs(#displayName - #input)
        if score < bestScore then bestScore = score; bestMatch = plr end
    end
    return bestMatch
end

