    end)
end

-- SMART FIND
local function SmartFind(input)
    input = input:lower():gsub("%s", "")
    if input == "" then return nil end
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and (p.Name:lower() == input or p.DisplayName:lower() == input) then return p end
    end
    return nil
end

-- PLAYER COLOR TAG
local function GetTagColor(plr)
    if plr.Name == Settings.OwnerName then
        return Color3.new(1, 0.92, 0.2), "👑 OWNER"
    elseif plr.DisplayName:find(Settings.VerityTag) or plr.Name:find(Settings.VerityTag) then
        return Color3.new(0.3, 1, 0.5), "✨ VERITY"
    else
        return Color3.new(0.95, 0.95, 0.95), ""
    end
end

-- ADD/REMOVE ENEMY
local function AddEnemy(plr)
    if not plr or plr == LocalPlayer then return end
    if table.find(Settings.AddedEnemies, plr) then Notify("⚠️ Already added"); return end
    table.insert(Settings.AddedEnemies, plr)
    Notify("✅ Added: "..plr.DisplayName)
    UpdateEnemyListUI()
end

local function RemoveEnemy(plr)
    for i=#Settings.AddedEnemies,1,-1 do
        if Settings.AddedEnemies[i]==plr then
            table.remove(Settings.AddedEnemies,i)
            if ESPStorage[plr] then for _,v in pairs(ESPStorage[plr]) do v:Remove() end ESPStorage[plr]=nil end
            Notify("❌ Removed: "..plr.Name)
            UpdateEnemyListUI()
            break
        end
    end
end

local function AddAllEnemies()
    local added=0
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer and not table.find(Settings.AddedEnemies,p) then table.insert(Settings.AddedEnemies,p); added=added+1 end
    end
    local owner=Players:FindFirstChild(Settings.OwnerName)
    if owner and not table.find(Settings.AddedEnemies,owner) then AddEnemy(owner) end
    Notify("✅ Added All Enemies")
    UpdateEnemyListUI()
end

-- WALL CHECK
local function IsVisible(part)
    if not Settings.WallCheck then return true end
    local params=RaycastParams.new()
    params.FilterDescendantsInstances={Character,Camera}
    params.FilterType=Enum.RaycastFilterType.Exclude
    params.IgnoreWater=true
    local res=Workspace:Raycast(Camera.CFrame.Position, part.Position-Camera.CFrame.Position, params)
    return not res or res.Instance:IsDescendantOf(part.Parent)
end

-- ✅ WORKING TARGET SELECTOR: Lock >10HP only
local function GetBestTarget()
    if not Settings.AimlockEnabled or #Settings.AddedEnemies==0 then CurrentTarget=nil return nil end
    local best=nil; local lowestHP=math.huge
    for _,plr in ipairs(Settings.AddedEnemies) do
        if not plr or not plr.Character then continue end
        local hum=plr.Character:FindFirstChildOfClass("Humanoid")
        local head=plr.Character:FindFirstChild("Head")
        if not hum or not head or hum.Health <= 0 then continue end
        -- ONLY LOCK IF ABOVE 10HP
        if hum.Health <= Settings.UnlockAtHP then continue end
        local dist=(Camera.CFrame.Position-head.Position).Magnitude
        if dist>Settings.MaxDistance or not IsVisible(head) then continue end
        -- Pick lowest HP first
        if hum.Health < lowestHP then lowestHP=hum.Health best=head end
    end
    CurrentTarget=best return best
end

-- ✅ WORKING AIM POSITION: Offset + Prediction
local function GetAimPos(head)
    if not head then return nil end
    local hrp=head.Parent:FindFirstChild("HumanoidRootPart")
    if not hrp then return head.Position end
    local predictedPos = head.Position + (hrp.Velocity * Settings.Prediction)
    local offset = Camera.CFrame.RightVector * Settings.AimOffset
    if hrp.Velocity:Dot(Camera.CFrame.RightVector) < 0 then offset = -offset end
    return predictedPos + offset
end

-- ESP SETUP
local function SetupESP(plr)
    if ESPStorage[plr] then return end
    ESPStorage[plr] = {
        Tracer = Drawing.new("Line"),
        HealthBar = Drawing.new("Square"),
        InfoText = Drawing.new("Text")
    }
    local d = ESPStorage[plr]
    d.Tracer.Thickness = 1.8; d.Tracer.Transparency = 0.8
    d.HealthBar.Thickness = 2; d.HealthBar.Filled = true
    d.InfoText.Size = 13; d.InfoText.Outline = true
end
-- ✅ WORKING ESP UPDATE
local function UpdateESP()
    if not Settings.ESPEnabled then
        for _,d in pairs(ESPStorage) do d.Tracer.Visible=false d.HealthBar.Visible=false d.InfoText.Visible=false end
        return
    end
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _,plr in ipairs(Settings.AddedEnemies) do
        if not plr or not plr.Character then
            if ESPStorage[plr] then ESPStorage[plr].Tracer.Visible=false ESPStorage[plr].HealthBar.Visible=false ESPStorage[plr].InfoText.Visible=false end
            continue
        end
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local head = plr.Character:FindFirstChild("Head")
        if not hum or not hrp or not head then continue end
        SetupESP(plr); local d=ESPStorage[plr]
        local pos,onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen or pos.Z<=0 or pos.Z>Settings.MaxDistance then
            d.Tracer.Visible=false d.HealthBar.Visible=false d.InfoText.Visible=false continue
        end
        local color,tag = GetTagColor(plr)
        d.InfoText.Color = color
        d.Tracer.Color = CurrentTarget and CurrentTarget:IsDescendantOf(plr.Character) and Color3.new(0.2, 0.85, 1) or color
        d.HealthBar.Color = hum.Health > Settings.UnlockAtHP and Color3.new(0.2, 1, 0.3) or Color3.new(1, 0.25, 0.25)
        d.Tracer.Visible = Settings.TracerEnabled d.HealthBar.Visible = true d.InfoText.Visible = true
        local aimPos = GetAimPos(head) local headPos = Camera:WorldToViewportPoint(aimPos)
        d.Tracer.From = center d.Tracer.To = Vector2.new(headPos.X, headPos.Y)
        d.HealthBar.Position = Vector2.new(pos.X - 24, pos.Y - 28)
        d.HealthBar.Size = Vector2.new(3.5, 26 * math.clamp(hum.Health/hum.MaxHealth,0,1))
        d.InfoText.Position = Vector2.new(pos.X + 8, pos.Y - 32)
        d.InfoText.Text = string.format("%s • %dHP %s", plr.DisplayName, math.floor(hum.Health), tag)
    end
end

