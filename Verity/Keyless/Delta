-- 🧠 SMART SEARCH: Find closest matching player
local function SmartFindPlayer(input)
    input = input:lower():gsub("%s", "")
    if input == "" then return nil end
    local bestMatch = nil
    local bestScore = math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local name = p.Name:lower()
            local disp = p.DisplayName:lower()
            -- Exact match first
            if name == input or disp == input then return p end
            -- Partial match scoring
            local score = math.abs(#name - #input) + (name:find(input) and 0 or 10) + (disp:find(input) and 0 or 10)
            if score < bestScore then
                bestScore = score
                bestMatch = p
            end
        end
    end
    return bestMatch
end

-- ADD / REMOVE ENEMY
local function AddEnemy(plr)
    if not plr then return end
    for _,e in ipairs(Settings.AddedEnemies) do
        if e == plr then Notify("⚠️ Already added"); return end
    end
    table.insert(Settings.AddedEnemies, plr)
    Notify("✅ Added: "..plr.DisplayName.." | @"..plr.Name)
    UpdateEnemyListUI()
end

local function RemoveEnemy(plr)
    for i = #Settings.AddedEnemies, 1, -1 do
        if Settings.AddedEnemies[i] == plr then
            table.remove(Settings.AddedEnemies, i)
            if ESPStorage[plr] then
                for _,v in pairs(ESPStorage[plr]) do v:Remove() end
                ESPStorage[plr] = nil
            end
            Notify("❌ Removed: "..plr.Name)
            UpdateEnemyListUI()
            break
        end
    end
end

-- ➕ ADD ALL PLAYERS AS ENEMIES
local function AddAllEnemies()
    local added = 0
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local exists = false
            for _,e in ipairs(Settings.AddedEnemies) do
                if e == p then exists = true; break end
            end
            if not exists then
                table.insert(Settings.AddedEnemies, p)
                added = added + 1
            end
        end
    end
    Notify("✅ Added ALL players: "..added.." total")
    UpdateEnemyListUI()
end

-- WALL CHECK
local function IsVisible(part)
    if not Settings.WallCheck then return true end
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {Character, Camera}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.IgnoreWater = true
    local rayResult = Workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, rayParams)
    return not rayResult or rayResult.Instance:IsDescendantOf(part.Parent)
end

-- 🎯 AIM: STRICTLY TARGET HUMAN HEAD
local function GetBestTarget()
    if not Settings.AimlockEnabled or #Settings.AddedEnemies == 0 then return nil end
    local closestTarget = nil
    local shortestDistance = math.huge

    for _, enemyPlayer in ipairs(Settings.AddedEnemies) do
        if not enemyPlayer or not enemyPlayer.Character then continue end
        local hum = enemyPlayer.Character:FindFirstChildOfClass("Humanoid")
        local head = enemyPlayer.Character:FindFirstChild("Head")
        -- ✅ ONLY LOCK IF ALIVE & HP > 10
        if not hum or not head or hum.Health <= Settings.UnlockBelowHP or hum.Health <= 0 then continue end
        local dist = (Camera.CFrame.Position - head.Position).Magnitude
        if dist > Settings.MaxDistance then continue end
        if not IsVisible(head) then continue end
        if dist < shortestDistance then
            shortestDistance = dist
            closestTarget = head
        end
    end
    return closestTarget
end

-- ESP + TRACER + HEALTHBAR
local function SetupESP(plr)
    if ESPStorage[plr] then return end
    ESPStorage[plr] = {
        Tracer = Drawing.new("Line"),
        HealthBar = Drawing.new("Square"),
        InfoText = Drawing.new("Text")
    }
    local d = ESPStorage[plr]
    d.Tracer.Thickness = 1.5
    d.Tracer.Color = Color3.new(1,1,1)
    d.HealthBar.Thickness = 2
    d.HealthBar.Filled = true
    d.InfoText.Size = 12
    d.InfoText.Outline = true
    d.InfoText.Color = Color3.new(1,1,1)
end

local function UpdateESP()
    if not Settings.ESPEnabled then
        for _,d in pairs(ESPStorage) do
            d.Tracer.Visible = false
            d.HealthBar.Visible = false
            d.InfoText.Visible = false
        end
        return
    end
    local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    for _,plr in ipairs(Settings.AddedEnemies) do
        if not plr or not plr.Character then
            if ESPStorage[plr] then
                ESPStorage[plr].Tracer.Visible = false
                ESPStorage[plr].HealthBar.Visible = false
                ESPStorage[plr].InfoText.Visible = false
            end
            continue
        end
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
        local head = plr.Character:FindFirstChild("Head")
        if not hum or not hrp or not head then continue end
        SetupESP(plr)
        local d = ESPStorage[plr]
        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if onScreen and pos.Z > 0 and pos.Z < Settings.MaxDistance then
            d.Tracer.Visible = Settings.TracerEnabled
            d.HealthBar.Visible = true
            d.InfoText.Visible = true
            local headPos = Camera:WorldToViewportPoint(head.Position)
            d.Tracer.From = screenCenter
            d.Tracer.To = Vector2.new(headPos.X, headPos.Y)
            d.HealthBar.Position = Vector2.new(pos.X - 22, pos.Y - 25)
            d.HealthBar.Size = Vector2.new(3, 25 * math.clamp(hum.Health / hum.MaxHealth, 0, 1))
            d.HealthBar.Color = hum.Health > 10 and Color3.new(0,1,0) or Color3.new(1,0.6,0) -- Yellow below 10HP
            d.InfoText.Position = Vector2.new(pos.X, pos.Y - 35)
            d.InfoText.Text = string.format("%s | %d HP", plr.DisplayName, math.floor(hum.Health))
        else
            d.Tracer.Visible = false
            d.HealthBar.Visible = false
            d.InfoText.Visible = false
        end
    end
end

-- 📋 ENEMY LIST WITH REMOVE X BUTTON
local EnemyListFrame
function UpdateEnemyListUI()
    -- Clear old buttons
    for _,btn in ipairs(EnemyListButtons) do btn:Destroy() end
    EnemyListButtons = {}

    local yOffset = 5
    for _,plr in ipairs(Settings.AddedEnemies) do
        if not plr:IsA("Player") then continue end
        local hum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
        local hp = hum and math.floor(hum.Health).." HP" or "Offline"

        -- Player Label
        local Entry = Instance.new("TextLabel")
        Entry.Parent = EnemyListFrame
        Entry.Size = UDim2.new(0.82, 0, 0, 28)
        Entry.Position = UDim2.new(0.02, 0, 0, yOffset)
        Entry.BackgroundTransparency = 0.9
        Entry.BackgroundColor3 = Color3.new(0.2,0.2,0.2)
        Entry.Text = plr.DisplayName.." | @"..plr.Name.." | "..hp
        Entry.TextColor3 = hum and hum.Health > 10 and Color3.new(1,1,1) or Color3.new(1,0.6,0)
        Entry.Font = Enum.Font.GothamSemibold
        Entry.TextSize = 11
        Entry.TextXAlignment = Enum.TextXAlignment.Left
        Entry.BorderSizePixel = 0
        table.insert(EnemyListButtons, Entry)

        -- Remove X Button
        local RemoveBtn = Instance.new("TextButton")
        RemoveBtn.Parent = EnemyListFrame
        RemoveBtn.Size = UDim2.new(0.12, 0, 0, 28)
        RemoveBtn.Position = UDim2.new(0.86, 0, 0, yOffset)
        RemoveBtn.BackgroundColor3 = Color3.new(0.8,0.1,0.1)
        RemoveBtn.Text = "X"
        RemoveBtn.TextColor3 = Color3.new(1,1,1)
        RemoveBtn.Font = Enum.Font.GothamBold
        RemoveBtn.TextSize = 12
        RemoveBtn.BorderSizePixel = 0
        RemoveBtn.MouseButton1Click:Connect(function() RemoveEnemy(plr) end)
        table.insert(EnemyListButtons, RemoveBtn)

        yOffset = yOffset + 32
    end

    -- Empty state
    if #Settings.AddedEnemies == 0 then
        local Empty = Instance.new("TextLabel")
        Empty.Parent = EnemyListFrame
        Empty.Size = UDim2.new(0.96, 0, 1, 0)
        Empty.Position = UDim2.new(0.02,0,0,0)
        Empty.BackgroundTransparency = 1
        Empty.Text = "No enemies added yet"
        Empty.TextColor3 = Color3.new(0.7,0.7,0.7)
        Empty.Font = Enum.Font.GothamSemibold
        Empty.TextSize = 11
        Empty.TextWrapped = true
        table.insert(EnemyListButtons, Empty)
    end
end

